# Copy this file to .env and fill in the values

# ── Frontend (prestarapi) ──────────────────────────────────────────────────────
# URL of your deployed API server (Railway, Render, Fly, etc.)
# Leave empty to use same-origin (when serving frontend and API from same host)
VITE_API_URL=https://your-api-server.railway.app

# ── Backend (api-server) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/prestarapi
JWT_SECRET=change-me-to-a-long-random-secret
PORT=8080
NODE_ENV=production
